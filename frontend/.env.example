# ======================
# FRONTEND ENVIRONMENT VARIABLES
# ======================

# API URLs
VITE_API_URL=http://localhost:5000/api
VITE_ML_URL=http://localhost:8000

# Application Settings
VITE_APP_NAME=Enerji-Su Yönetim Platformu
VITE_APP_VERSION=1.0.0

# Map Configuration (Optional - for future features)
VITE_MAP_API_KEY=your_map_api_key_here

# Feature Flags
VITE_ENABLE_OPTIMIZATION=true
VITE_ENABLE_ALERTS=true
VITE_ENABLE_SCENARIOS=true

# Refresh Intervals (milliseconds)
VITE_DATA_REFRESH_INTERVAL=300000
VITE_CHART_REFRESH_INTERVAL=60000

# Chart Configuration
VITE_DEFAULT_CHART_DAYS=30
VITE_MAX_CHART_POINTS=100
