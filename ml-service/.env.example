# ======================
# ML SERVICE ENVIRONMENT VARIABLES
# ======================

# Python Environment
PYTHON_ENV=development

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=energy_water_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123

# Model Configuration
MODEL_PATH=./app/trained_models
MODEL_VERSION=1.0.0

# Training Configuration
TRAIN_TEST_SPLIT=0.7
VALIDATION_SPLIT=0.15
RANDOM_STATE=42

# LSTM Model Parameters
LSTM_EPOCHS=100
LSTM_BATCH_SIZE=32
LSTM_LEARNING_RATE=0.001
LSTM_HIDDEN_UNITS=64
LSTM_DROPOUT=0.2
LSTM_LOOKBACK_DAYS=30

# Prophet Model Parameters
PROPHET_CHANGEPOINT_PRIOR=0.05
PROPHET_SEASONALITY_PRIOR=10
PROPHET_SEASONALITY_MODE=multiplicative

# XGBoost Model Parameters
XGBOOST_N_ESTIMATORS=100
XGBOOST_MAX_DEPTH=6
XGBOOST_LEARNING_RATE=0.1
XGBOOST_MIN_CHILD_WEIGHT=1

# Optimization Parameters
OPT_ALGORITHM=linear_programming
OPT_MAX_ITERATIONS=1000
OPT_CONVERGENCE_THRESHOLD=0.0001

# Performance Thresholds
MIN_ACCURACY_THRESHOLD=0.85
MIN_R2_SCORE=0.80
MAX_MAPE=15.0

# Cache Configuration
CACHE_PREDICTIONS=true
CACHE_TTL=3600

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/ml_service.log
