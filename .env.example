# ======================
# DOCKER COMPOSE ENVIRONMENT VARIABLES
# ======================

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=energy_water_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Backend
NODE_ENV=development
PORT=5000
JWT_SECRET=your-super-secret-jwt-key-change-this

# ML Service
ML_SERVICE_URL=http://ml-service:8000
PYTHON_ENV=development

# External API Keys (Gerçek API anahtarlarınızı buraya ekleyin!)
NASA_API_KEY=DEMO_KEY
OPENWEATHER_API_KEY=your_openweather_api_key_here
MGM_API_KEY=your_mgm_api_key_here
DSI_API_KEY=your_dsi_api_key_here
TUIK_API_KEY=your_tuik_api_key_here

# Frontend
VITE_API_URL=http://localhost:5000/api
VITE_ML_URL=http://localhost:8000

# Logging
LOG_LEVEL=info

